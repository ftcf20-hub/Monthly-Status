<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FTCF Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
rel="stylesheet">
<style>
body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
.bank-card { background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%); }
.glass-effect { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); }
</style>
</head>
<body class="pb-10">
<!-- Header Section -->
<div class="bank-card text-white p-8 rounded-b-[40px] shadow-2xl mb-6">
<h1 class="text-2xl font-bold text-center mb-6">Family Trust & Care Foundation</h1>
<div class="glass-effect p-6 rounded-2xl border border-white/20">
<p class="text-xs uppercase tracking-widest opacity-80 mb-1">Welcome
Administrator</p>
<h2 class="text-xl font-semibold italic">"Trust & Service"</h2>
</div>
</div>
<!-- Search Bar -->
<div class="px-4 mb-6">
<input type="text" id="searchInput" placeholder="🔍 Search member name..."
class="w-full p-4 rounded-2xl border-none shadow-lg focus:ring-2 focus:ring-blue-500
outline-none text-lg">
</div>
<!-- Stats Cards -->
<div class="grid grid-cols-2 gap-4 px-4 mb-8">
<!-- MONTH CARD (Ab H1 se link hai) -->
<div class="bg-white p-5 rounded-3xl shadow-md border-b-4 border-blue-600">
<p class="text-[10px] font-bold text-gray-400 uppercase">Month</p>
<h3 id="month-display" class="text-lg font-bold text-slate-800
tracking-tight">Loading...</h3>
</div>
<!-- TOTAL COLLECTION --> <div class="bg-white p-5 rounded-3xl shadow-md border-b-4 border-green-500">
<p class="text-[10px] font-bold text-gray-400 uppercase">Total Collection</p>
<h3 id="total-collection" class="text-lg font-bold text-green-600">Rs. 0</h3>
</div>
</div>
<!-- Members List Section -->
<div class="px-4">
<div class="flex justify-between items-center mb-4 px-2">
<h2 class="text-xl font-bold text-slate-800">Members Status</h2>
<span id="member-count" class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1
rounded-full">24 Members</span>
</div>
<div id="member-list" class="space-y-3">
<!-- Data will load here -->
<p class="text-center text-gray-500">Connecting to database...</p>
</div>
</div>
<script>
// --- CONFIGURATION ---
const SHEET_ID = "1hUEigyVt9FcLdeT-2G44mcUMo-r3gSb7AN0XcXilMVw;" // <--- Apni
Sheet ID yahan paste karein
const BASE_URL =
`https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`;
async function loadDashboardData() {
try {
// 1. Fetch Month from H1[span_1](start_span)[span_1](end_span)
const monthUrl = `${BASE_URL}&range=H1`;
const monthRes = await fetch(monthUrl);
const monthTxt = await monthRes.text();
const monthJson = JSON.parse(monthTxt.substr(47).slice(0, -2));
const currentMonth = monthJson.table.rows[0]?.c[0]?.v || "Update H1";
document.getElementById('month-display').innerText = currentMonth;
// 2. Fetch Members Data (A2:E25)[span_2](start_span)[span_2](end_span)
const dataUrl = `${BASE_URL}&range=A2:E25`;
const response = await fetch(dataUrl);
const text = await response.text();
const data = JSON.parse(text.substr(47).slice(0, -2));
renderMembers(data.table.rows); } catch (error) {
console.error("Error loading data:", error);
document.getElementById('member-list').innerHTML = "Check Spreadsheet ID or
Internet.";
}
}
function renderMembers(rows) {
const list = document.getElementById('member-list');
list.innerHTML = '';
let total = 0;
rows.forEach(row => {
const name = row.c[0]?.v || "Unknown";
const amount = row.c[1]?.v || 0;
const status = row.c[2]?.v || "UNPAID";
if(status.toUpperCase() === 'PAID') total += amount;
const card = document.createElement('div');
card.className = "bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex
items-center justify-between";
card.innerHTML = `
<div class="flex items-center gap-4">
<div class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center
text-blue-600 font-bold text-lg">
${name.charAt(0)}
</div>
<div>
<h4 class="font-bold text-slate-800">${name}</h4>
<p class="text-[10px] text-gray-400 uppercase tracking-tighter">Foundation
Member</p>
</div>
</div>
<div class="text-right">
<p class="font-bold text-blue-900 text-sm">Rs. ${amount}</p>
<span class="text-[9px] px-2 py-0.5 rounded-md font-bold
${status.toUpperCase() === 'PAID' ? 'bg-green-100 text-green-600' : 'bg-red-100
text-red-600'}">
${status}
</span>
</div>
`;
list.appendChild(card); });
document.getElementById('total-collection').innerText = `Rs. ${total.toLocaleString()}`;
}
// Run on load
loadDashboardData();
// Simple Search Filter
document.getElementById('searchInput').addEventListener('input', (e) => {
const term = e.target.value.toLowerCase();
const cards = document.querySelectorAll('#member-list > div');
cards.forEach(card => {
const name = card.querySelector('h4').innerText.toLowerCase();
card.style.display = name.includes(term) ? 'flex' : 'none';
});
});
</script>
</body>
</html>
